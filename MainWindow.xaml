                            <Button  Style="{StaticResource BtnImport}"      Grid.Column="2" Content="⬇ Import" Tag="TxtBgmFile" Click="ImportFile_Click"/>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="LIVEAREA PREVIEW IMAGES"/>
