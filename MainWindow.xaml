                                <Button  Style="{StaticResource BtnBrowseField}" Grid.Column="1" Content="📁" Tag="TxtHomePreview" Click="BrowseFile_Click"/>
                                <Button  Style="{StaticResource BtnImport}"      Grid.Column="2" Content="⬇ Import" Tag="TxtHomePreview" Click="ImportFile_Click"/>
                            </Grid>
                            <Border x:Name="ThumbHomePreviewBorder" Margin="0,6,0,0"
