<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ThemeEditorWPF"
        Title="PS Vita Theme Creator by DaskGaming" Height="800" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowState="Maximized"
        Background="#080808"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- GEL PRIMARY (orange) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground"      Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="22,11"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GelBase" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#ff9933" Offset="0"/>
                                        <GradientStop Color="#cc5500" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="GelShine" CornerRadius="8,8,0,0"
                                    Height="12" VerticalAlignment="Top"
                                    Margin="4,2,4,0" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#80ffffff" Offset="0"/>
                                        <GradientStop Color="#00ffffff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#ffaa44" Offset="0"/>
                                            <GradientStop Color="#dd6600" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#aa4400" Offset="0"/>
                                            <GradientStop Color="#cc5500" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="GelShine" Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#222222" Offset="0"/>
                                            <GradientStop Color="#181818" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#444444"/>
                                <Setter TargetName="GelShine" Property="Opacity" Value="0.1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GEL SECONDARY (grey) -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Foreground"      Value="#dddddd"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="22,11"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GelBase" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#484848" Offset="0"/>
                                        <GradientStop Color="#242424" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="GelShine" CornerRadius="8,8,0,0"
                                    Height="12" VerticalAlignment="Top"
                                    Margin="4,2,4,0" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#50ffffff" Offset="0"/>
                                        <GradientStop Color="#00ffffff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#585858" Offset="0"/>
                                            <GradientStop Color="#343434" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#111111" Offset="0"/>
                                            <GradientStop Color="#222222" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="GelShine" Property="Opacity" Value="0.2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#1a1a1a" Offset="0"/>
                                            <GradientStop Color="#111111" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter TargetName="GelShine" Property="Opacity" Value="0.05"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GEL GHOST (outlined) -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Foreground"      Value="#888888"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#2e2e2e"/>
            <Setter Property="Padding"         Value="22,11"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GelBase" CornerRadius="8"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#282828" Offset="0"/>
                                        <GradientStop Color="#161616" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="GelShine" CornerRadius="8,8,0,0"
                                    Height="10" VerticalAlignment="Top"
                                    Margin="5,3,5,0" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#30ffffff" Offset="0"/>
                                        <GradientStop Color="#00ffffff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GelBase" Property="BorderBrush" Value="#ff7d00"/>
                                <Setter Property="Foreground" Value="#dddddd"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#0a0a0a" Offset="0"/>
                                            <GradientStop Color="#141414" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter TargetName="GelShine" Property="Opacity" Value="0.05"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="#1e1e1e"/>
            <Setter Property="Foreground"      Value="#f0f0f0"/>
            <Setter Property="BorderBrush"     Value="#2e2e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="11,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#ff7d00"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#ff7d00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="#ffffff"/>
            <Setter Property="Foreground"      Value="#111111"/>
            <Setter Property="BorderBrush"     Value="#2e2e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="11,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Padding"    Value="10,6"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="Background" Value="#ffe0b2"/>
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="Background" Value="#fff3e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnBrowseField" TargetType="Button">
            <Setter Property="Foreground"      Value="#ff7d00"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="38"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="6,0,0,0"/>
            <Setter Property="ToolTip"         Value="Browse for file"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GelBase" CornerRadius="6">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#383838" Offset="0"/>
                                        <GradientStop Color="#1e1e1e" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border CornerRadius="6,6,0,0" Height="10" VerticalAlignment="Top"
                                    Margin="3,2,3,0" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#30ffffff" Offset="0"/>
                                        <GradientStop Color="#00ffffff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GelBase" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#484848" Offset="0"/>
                                            <GradientStop Color="#2e2e2e" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnImport" TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
            <Setter Property="Padding"  Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin"   Value="6,0,0,0"/>
            <Setter Property="ToolTip"  Value="Copy file into theme folder and set filename"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#e0e0e0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldDesc" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#555555"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#ff7d00"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,22,0,14"/>
        </Style>
        <Style x:Key="ColorPreview" TargetType="Border">
            <Setter Property="Width"           Value="36"/>
            <Setter Property="CornerRadius"    Value="5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#2e2e2e"/>
            <Setter Property="Margin"          Value="6,0,0,0"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1c1c1c"
                BorderThickness="0,0,0,1" BorderBrush="#333333">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="5" Height="22" Background="#ff7d00"
                            CornerRadius="2" Margin="0,0,12,0"/>
                    <TextBlock Text="PS Vita Theme Creator by DaskGaming"
                               Foreground="#f0f0f0" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TxtHeaderPath" HorizontalAlignment="Right"
                           Foreground="#2e2e2e" FontSize="11" VerticalAlignment="Center"
                           MaxWidth="480" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="#1c1c1c"
                    BorderThickness="0,0,1,0" BorderBrush="#333333">
                <DockPanel Margin="14,24,14,16" LastChildFill="False">

                    <!-- Exit button docked to bottom -->
                    <Button DockPanel.Dock="Bottom"
                            Content="✕  Exit"
                            Click="BtnExit_Click"
                            Cursor="Hand"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ExitBorder" Background="Transparent"
                                        BorderBrush="#2a2a2a" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#444444" FontSize="11"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ExitBorder" Property="BorderBrush" Value="#993333"/>
                                        <Setter TargetName="ExitBorder" Property="Background" Value="#1a0a0a"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ExitBorder" Property="Background" Value="#330000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Save status docked to bottom above exit -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="10,9" CornerRadius="6"
                            Background="#242424" BorderBrush="#333333" BorderThickness="1">
                        <TextBlock x:Name="TxtSaveStatus" Foreground="#666666"
                                   FontSize="11" TextWrapping="Wrap"
                                   Text="Not yet saved."/>
                    </Border>

                    <!-- Step list fills remaining space -->
                    <ItemsControl x:Name="StepList" DockPanel.Dock="Top">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" CornerRadius="7" Padding="10,9"
                                        Background="{Binding RowBg}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="22" Height="22" CornerRadius="11"
                                                Background="{Binding CircleBg}"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding NumberText}"
                                                       Foreground="{Binding CircleFg}"
                                                       FontSize="10" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   Foreground="{Binding LabelColor}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </DockPanel>
            </Border>

            <!-- CONTENT -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          Background="#0a0a0a" x:Name="ContentScroller">
                <Grid Margin="44,32,44,32">

                    <!-- STEP 0: Welcome -->
                    <StackPanel x:Name="PanelWelcome" Visibility="Visible">
                        <TextBlock Text="PS Vita Theme Creator by DaskGaming" Foreground="#f0f0f0"
                                   FontSize="26" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="What would you like to do?"
                                   Foreground="#444444" FontSize="14" Margin="0,0,0,40"/>

                        <!-- New Theme card -->
                        <Border Background="#111111" CornerRadius="10"
                                BorderBrush="#2e2e2e" BorderThickness="1"
                                Margin="0,0,0,16" Cursor="Hand"
                                MouseLeftButtonUp="WelcomeNewTheme_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#ff7d00"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="28,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="10"
                                        Background="#ff7d00" VerticalAlignment="Center">
                                    <TextBlock Text="+" Foreground="#ffffff"
                                               FontSize="26" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="Create New Theme"
                                               Foreground="#f0f0f0" FontSize="16" FontWeight="Bold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Start from scratch. Set a name, pick a folder, and build your theme step by step. Note: images are not supplied — you will need to provide your own."
                                               Foreground="#555555" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Edit Existing card -->
                        <Border Background="#111111" CornerRadius="10"
                                BorderBrush="#2e2e2e" BorderThickness="1"
                                Cursor="Hand"
                                MouseLeftButtonUp="WelcomeEditTheme_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#ff7d00"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="28,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="10"
                                        Background="#2a2a2a" VerticalAlignment="Center">
                                    <TextBlock Text="&#x270E;" Foreground="#ff7d00"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="Edit Existing Theme"
                                               Foreground="#f0f0f0" FontSize="16" FontWeight="Bold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Open an existing theme.xml file and edit its settings."
                                               Foreground="#555555" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Download Theme card -->
                        <Border Background="#111111" CornerRadius="10"
                                BorderBrush="#2e2e2e" BorderThickness="1"
                                Margin="0,16,0,0" Cursor="Hand"
                                MouseLeftButtonUp="WelcomeDownloadTheme_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#ff7d00"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="28,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="10"
                                        Background="#2a2a2a" VerticalAlignment="Center">
                                    <TextBlock Text="&#x2193;" Foreground="#ff7d00"
                                               FontSize="24" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="Download a Theme"
                                               Foreground="#f0f0f0" FontSize="16" FontWeight="Bold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Browse and download PS Vita themes from PSVita Custom Themes at psvt.ovh — opens in your default browser."
                                               Foreground="#555555" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Create Icons card -->
                        <Border Background="#111111" CornerRadius="10"
                                BorderBrush="#2e2e2e" BorderThickness="1"
                                Margin="0,16,0,0" Cursor="Hand"
                                MouseLeftButtonUp="WelcomeIconCreator_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#ff7d00"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="28,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="10"
                                        Background="#2a2a2a" VerticalAlignment="Center">
                                    <TextBlock Text="&#x2726;" Foreground="#ff7d00"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="Create Icons"
                                               Foreground="#f0f0f0" FontSize="16" FontWeight="Bold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Recolor existing PS Vita theme icons by changing the background and foreground colors using the color wheel."
                                               Foreground="#555555" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Image Reference card -->
                        <Border Background="#111111" CornerRadius="10"
                                BorderBrush="#2e2e2e" BorderThickness="1"
                                Margin="0,16,0,0" Cursor="Hand"
