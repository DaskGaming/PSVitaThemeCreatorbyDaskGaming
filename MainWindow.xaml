                                    <TextBlock Text="View all required image files, resolutions, and file size limits for a complete PS Vita theme."
                                               Foreground="#555555" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- IMAGE REFERENCE PANEL -->
                    <StackPanel x:Name="PanelImageRef" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="← Back" Style="{StaticResource BtnGhost}"
                                    Padding="14,8" Click="BtnImageRefBack_Click"/>
                        </StackPanel>
                        <TextBlock Text="Image Reference" Foreground="#f0f0f0"
                                   FontSize="22" FontWeight="Bold" Margin="0,16,0,4"/>
                        <TextBlock Foreground="#444444" FontSize="13" Margin="0,0,0,24" TextWrapping="Wrap"
                                   Text="All images must be provided by you — they are not included with this tool. Every image file required for a complete PS Vita theme is listed below."/>

                        <!-- Table header -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="File Name"  Grid.Column="0" Foreground="#ff7d00" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="Used For"   Grid.Column="1" Foreground="#ff7d00" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="Resolution" Grid.Column="2" Foreground="#ff7d00" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="Max Size"   Grid.Column="3" Foreground="#ff7d00" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="Notes"      Grid.Column="4" Foreground="#ff7d00" FontSize="10" FontWeight="Bold"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#2a2a2a" Margin="0,0,0,10"/>

                        <TextBlock Text="LOCKSCREEN" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,4,0,6"/>
                        <local:ImageRefRow FileName="lockscreen.png"          UsedFor="Lockscreen wallpaper"     Resolution="480x272"   MaxSize="200KB" Notes="Displayed behind clock on lock screen"/>
                        <local:ImageRefRow FileName="preview_lockscreen.png"  UsedFor="Repository preview"       Resolution="240x136"   MaxSize="50KB"  Notes="Shown in PS Store / Repository listing"/>

                        <Rectangle Height="1" Fill="#1e1e1e" Margin="0,10,0,10"/>
                        <TextBlock Text="LIVEAREA PAGES (×10)" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <local:ImageRefRow FileName="bg1.png – bg10.png"      UsedFor="Page background"          Resolution="960x544"   MaxSize="300KB" Notes="Full-res background for each LiveArea page"/>
                        <local:ImageRefRow FileName="bg1t.png – bg10t.png"    UsedFor="Page thumbnail"           Resolution="240x136"   MaxSize="50KB"  Notes="Small preview shown in page switcher"/>

                        <Rectangle Height="1" Fill="#1e1e1e" Margin="0,10,0,10"/>
                        <TextBlock Text="NOTIFICATION BAR" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <local:ImageRefRow FileName="notices.png"              UsedFor="No notifications icon"    Resolution="36x36"     MaxSize="20KB"  Notes="Bell icon when no notices are pending"/>
                        <local:ImageRefRow FileName="notice.png"               UsedFor="New notification icon"    Resolution="36x36"     MaxSize="20KB"  Notes="Bell icon when new notices are present"/>

                        <Rectangle Height="1" Fill="#1e1e1e" Margin="0,10,0,10"/>
                        <TextBlock Text="PAGE INDICATORS" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <local:ImageRefRow FileName="basePage.png"             UsedFor="Unselected page dot"      Resolution="26x26"     MaxSize="10KB"  Notes="Dot shown for non-active pages"/>
                        <local:ImageRefRow FileName="curPage.png"              UsedFor="Selected page dot"        Resolution="26x26"     MaxSize="10KB"  Notes="Dot shown for the currently active page"/>

                        <Rectangle Height="1" Fill="#1e1e1e" Margin="0,10,0,10"/>
                        <TextBlock Text="HOME &amp; PREVIEW" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <local:ImageRefRow FileName="preview_page.png"         UsedFor="Home preview"             Resolution="480x272"   MaxSize="200KB" Notes="Theme preview shown in Settings"/>
                        <local:ImageRefRow FileName="preview_thumbnail.png"    UsedFor="Package thumbnail"        Resolution="240x136"   MaxSize="50KB"  Notes="Thumbnail in Repository / theme store"/>

                        <Rectangle Height="1" Fill="#1e1e1e" Margin="0,10,0,10"/>
                        <TextBlock Text="APP ICONS (×17)" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <local:ImageRefRow FileName="icon_web.png"             UsedFor="Browser"                  Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_calendar.png"        UsedFor="Calendar"                 Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_photos.png"          UsedFor="Camera / Photos"          Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_mail.png"            UsedFor="Email"                    Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_friends.png"         UsedFor="Friends"                  Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_cma.png"             UsedFor="Content Manager"          Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_messages.png"        UsedFor="Messages"                 Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_music.png"           UsedFor="Music"                    Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_near.png"            UsedFor="Near"                     Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_parental.png"        UsedFor="Parental Controls"        Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_party.png"           UsedFor="Party / Voice Chat"       Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_ps3link.png"         UsedFor="PS3 Link"                 Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_ps4link.png"         UsedFor="PS4 Link"                 Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_power.png"           UsedFor="Power"                    Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_settings.png"        UsedFor="Settings"                 Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_trophies.png"        UsedFor="Trophies"                 Resolution="48x48"     MaxSize="15KB"  Notes=""/>
                        <local:ImageRefRow FileName="icon_videos.png"          UsedFor="Video"                    Resolution="48x48"     MaxSize="15KB"  Notes=""/>

                        <Rectangle Height="1" Fill="#1e1e1e" Margin="0,10,0,10"/>
                        <TextBlock Text="AUDIO" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                        <local:ImageRefRow FileName="bgm.at9"                  UsedFor="Background music"         Resolution="AT9 audio" MaxSize="4MB"   Notes="Sony ATRAC9 format — convert with at9tool"/>

                    </StackPanel>

                    <!-- STEP 1: Setup -->
                    <StackPanel x:Name="PanelSetup" Visibility="Collapsed">
                        <TextBlock Text="Theme Setup" Foreground="#f0f0f0"
                                   FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Name your theme, choose an author, and pick where to save it."
                                   Foreground="#444444" FontSize="13" Margin="0,0,0,28"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="IDENTITY" Margin="0,0,0,14"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Theme Name"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Displayed in PS Vita Settings and the Repository."/>
                        <TextBox   Style="{StaticResource InputStyle}"  x:Name="TxtTitle" Margin="0,0,0,16"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Author / Provider"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Your name or studio shown in the Repository listing."/>
                        <TextBox   Style="{StaticResource InputStyle}"  x:Name="TxtProvider" Margin="0,0,0,6"/>
                        <CheckBox  x:Name="ChkSyncLangs" IsChecked="True" Margin="0,4,0,4"
                                   Foreground="#444444" FontSize="11"
                                   Content="Sync title to all language variants (da, de, es, fi, fr, it, nl, no, pl, pt, ru, sv)"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="SAVE LOCATION"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Theme Folder"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Choose a location and a folder named after your theme will be created automatically."/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox  Style="{StaticResource InputStyle}" x:Name="TxtThemeFolder"
                                      IsReadOnly="True" Text="No folder selected"/>
                            <Button   Grid.Column="1" Content="Choose Location" Margin="8,0,0,0"
                                      Style="{StaticResource BtnSecondary}" Padding="16,9"
                                      Click="BtnPickFolder_Click"/>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="MISC"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Content Version"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Internal version string for the theme package (e.g. 01.00)."/>
                        <TextBox   Style="{StaticResource InputStyle}"  x:Name="TxtContentVer" Text="01.00"/>
                    </StackPanel>

                    <!-- STEP 2: Lockscreen -->
                    <StackPanel x:Name="PanelLockscreen" Visibility="Collapsed">
                        <TextBlock Text="Lockscreen" Foreground="#f0f0f0"
                                   FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Set the background image and colors for the lockscreen."
                                   Foreground="#444444" FontSize="13" Margin="0,0,0,28"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="BACKGROUND IMAGE" Margin="0,0,0,14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Lockscreen Image" Foreground="#e0e0e0" FontSize="13" FontWeight="SemiBold"/>
</StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                            <TextBlock Text="File Name: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="lockscreen.png" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="Resolution: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="480x272" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="File Size: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="max 200KB" Foreground="#666666" FontSize="10" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="PNG displayed as the lockscreen wallpaper."/>
                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource InputStyle}" x:Name="TxtLsFilePath" Text=""/>
                                <Button  Style="{StaticResource BtnBrowseField}" Grid.Column="1" Content="📁" Tag="TxtLsFilePath" Click="BrowseFile_Click"/>
                                <Button  Style="{StaticResource BtnImport}"      Grid.Column="2" Content="⬇ Import" Tag="TxtLsFilePath" Click="ImportFile_Click"/>
                            </Grid>
                            <Border x:Name="ThumbLsFilePathBorder" Margin="0,6,0,0"
                                    Background="#111111" CornerRadius="6"
                                    BorderBrush="#2e2e2e" BorderThickness="1"
                                    Height="90" Visibility="Collapsed"
                                    HorizontalAlignment="Left">
                                <Image x:Name="ThumbLsFilePath" Height="86" MaxWidth="160"
                                       Stretch="Uniform" Margin="2"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="CLOCK"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Clock Color (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Color of the clock shown on the lockscreen."/>
                        <local:ColorPickerControl x:Name="TxtDateColor" ValueChanged="ColorPicker_ValueChanged" ArgbValue="ffffffff" Margin="0,0,0,16"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Clock Position"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Where the clock appears on the lockscreen."/>
                        <ComboBox  Style="{StaticResource ComboStyle}"  x:Name="CmbDateLayout" Margin="0,0,0,16"
                                   SelectionChanged="CmbAny_Changed">
                            <ComboBoxItem Content="0"  Tag="0" IsSelected="True"/>
                            <ComboBoxItem Content="1"     Tag="1"/>
                            <ComboBoxItem Content="2" Tag="2"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="NOTIFICATION BAR COLORS"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Bar Background (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Background of the notification bar at the top of the lockscreen."/>
                        <local:ColorPickerControl x:Name="TxtNotifyBgColor" ValueChanged="ColorPicker_ValueChanged" ArgbValue="ff000000" Margin="0,0,0,16"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Border Color (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Border line on the lockscreen notification bar."/>
                        <local:ColorPickerControl x:Name="TxtNotifyBorderColor" ArgbValue="ffcccccc" Margin="0,0,0,16"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Font Color (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Text color in the lockscreen notification bar."/>
                        <local:ColorPickerControl x:Name="TxtNotifyFontColor" ValueChanged="ColorPicker_ValueChanged" ArgbValue="ffffffff" Margin="0,0,0,16"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="PREVIEW IMAGE"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Lockscreen Preview" Foreground="#e0e0e0" FontSize="13" FontWeight="SemiBold"/>
</StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                            <TextBlock Text="File Name: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="preview_lockscreen.png" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="Resolution: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="240x136" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="File Size: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="max 50KB" Foreground="#666666" FontSize="10" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Preview image of your lockscreen shown in the Repository."/>
                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource InputStyle}" x:Name="TxtStartPreview" Text=""/>
                                <Button  Style="{StaticResource BtnBrowseField}" Grid.Column="1" Content="📁" Tag="TxtStartPreview" Click="BrowseFile_Click"/>
                                <Button  Style="{StaticResource BtnImport}"      Grid.Column="2" Content="⬇ Import" Tag="TxtStartPreview" Click="ImportFile_Click"/>
                            </Grid>
                            <Border x:Name="ThumbStartPreviewBorder" Margin="0,6,0,0"
                                    Background="#111111" CornerRadius="6"
                                    BorderBrush="#2e2e2e" BorderThickness="1"
                                    Height="90" Visibility="Collapsed"
                                    HorizontalAlignment="Left">
                                <Image x:Name="ThumbStartPreview" Height="86" MaxWidth="160"
                                       Stretch="Uniform" Margin="2"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- STEP 3: Notification Bar -->
                    <StackPanel x:Name="PanelNotifBar" Visibility="Collapsed">
                        <TextBlock Text="Notification Bar" Foreground="#f0f0f0"
                                   FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Customize the LiveArea notification bar colors and icons."
                                   Foreground="#444444" FontSize="13" Margin="0,0,0,28"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="COLORS" Margin="0,0,0,14"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Bar Background (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Background of the top bar in the LiveArea."/>
                        <local:ColorPickerControl x:Name="TxtBarColor" ValueChanged="ColorPicker_ValueChanged" ArgbValue="ff000000" Margin="0,0,0,16"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Icon Color (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Color of icons in the LiveArea top bar."/>
                        <local:ColorPickerControl x:Name="TxtIndicatorColor" ValueChanged="ColorPicker_ValueChanged" ArgbValue="ffff7d00" Margin="0,0,0,16"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Text Color (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Font color of text in the LiveArea top bar."/>
                        <local:ColorPickerControl x:Name="TxtNoticeFontColor" ValueChanged="ColorPicker_ValueChanged" ArgbValue="ffffffff" Margin="0,0,0,16"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Icon Glow Color (AARRGGBB)"/>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Highlight glow on icons in the LiveArea top bar."/>
                        <local:ColorPickerControl x:Name="TxtNoticeGlowColor" ArgbValue="ffca0000" Margin="0,0,0,16"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="NOTICE ICONS"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="No-Notice Icon" Foreground="#e0e0e0" FontSize="13" FontWeight="SemiBold"/>
</StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                            <TextBlock Text="File Name: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="notices.png" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="Resolution: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="36x36" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="File Size: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="max 20KB" Foreground="#666666" FontSize="10" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Icon in the top-right when there are no notifications."/>
                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource InputStyle}" x:Name="TxtNoNoticeFile" Text=""/>
                                <Button  Style="{StaticResource BtnBrowseField}" Grid.Column="1" Content="📁" Tag="TxtNoNoticeFile" Click="BrowseFile_Click"/>
                                <Button  Style="{StaticResource BtnImport}"      Grid.Column="2" Content="⬇ Import" Tag="TxtNoNoticeFile" Click="ImportFile_Click"/>
                            </Grid>
                            <Border x:Name="ThumbNoNoticeFileBorder" Margin="0,6,0,0"
                                    Background="#111111" CornerRadius="6"
                                    BorderBrush="#2e2e2e" BorderThickness="1"
                                    Height="90" Visibility="Collapsed"
                                    HorizontalAlignment="Left">
                                <Image x:Name="ThumbNoNoticeFile" Height="86" MaxWidth="160"
                                       Stretch="Uniform" Margin="2"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="New-Notice Icon" Foreground="#e0e0e0" FontSize="13" FontWeight="SemiBold"/>
</StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                            <TextBlock Text="File Name: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="notice.png" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="Resolution: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="36x36" Foreground="#666666" FontSize="10" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <TextBlock Text="File Size: " Foreground="#444444" FontSize="10" FontFamily="Consolas"/>
                            <TextBlock Text="max 20KB" Foreground="#666666" FontSize="10" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource FieldDesc}"  Text="Icon shown when you have a new notification."/>
                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource InputStyle}" x:Name="TxtNewNoticeFile" Text=""/>
                                <Button  Style="{StaticResource BtnBrowseField}" Grid.Column="1" Content="📁" Tag="TxtNewNoticeFile" Click="BrowseFile_Click"/>
                                <Button  Style="{StaticResource BtnImport}"      Grid.Column="2" Content="⬇ Import" Tag="TxtNewNoticeFile" Click="ImportFile_Click"/>
                            </Grid>
                            <Border x:Name="ThumbNewNoticeFileBorder" Margin="0,6,0,0"
                                    Background="#111111" CornerRadius="6"
                                    BorderBrush="#2e2e2e" BorderThickness="1"
                                    Height="90" Visibility="Collapsed"
                                    HorizontalAlignment="Left">
                                <Image x:Name="ThumbNewNoticeFile" Height="86" MaxWidth="160"
                                       Stretch="Uniform" Margin="2"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- STEP 4: Pages -->
                    <StackPanel x:Name="PanelPages" Visibility="Collapsed">
                        <TextBlock Text="Page Backgrounds" Foreground="#f0f0f0"
                                   FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Set background images and appearance for each LiveArea page."
                                   Foreground="#444444" FontSize="13" Margin="0,0,0,20"/>

                        <Border Background="#111111" CornerRadius="8"
                                BorderBrush="#1a1a1a" BorderThickness="1"
                                Padding="16,12" Margin="0,0,0,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Page" Foreground="#666666" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource ComboStyle}"
                                          x:Name="CmbPageSelect" Width="140"
                                          SelectionChanged="CmbPageSelect_Changed"
                                          HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Page 1"  Tag="0" IsSelected="True"/>
                                    <ComboBoxItem Content="Page 2"  Tag="1"/>
                                    <ComboBoxItem Content="Page 3"  Tag="2"/>
                                    <ComboBoxItem Content="Page 4"  Tag="3"/>
                                    <ComboBoxItem Content="Page 5"  Tag="4"/>
                                    <ComboBoxItem Content="Page 6"  Tag="5"/>
                                    <ComboBoxItem Content="Page 7"  Tag="6"/>
                                    <ComboBoxItem Content="Page 8"  Tag="7"/>
                                    <ComboBoxItem Content="Page 9"  Tag="8"/>
                                    <ComboBoxItem Content="Page 10" Tag="9"/>
                                </ComboBox>
                                <Button Grid.Column="2" Content="Prev" Margin="12,0,0,0"
