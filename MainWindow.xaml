                                                     Content="📁" Tag="{Binding}" Click="BrowseIconField_Click"/>
                                            <Button  Style="{StaticResource BtnImport}" Grid.Column="2"
                                                     Content="⬇ Import" Tag="{Binding}" Click="ImportIconField_Click"/>
                                        </Grid>
                                        <Border Margin="0,6,0,0"
