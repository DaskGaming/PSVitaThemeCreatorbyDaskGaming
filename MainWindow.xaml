                                                AlignmentY="Center"
                                                TileMode="None"
                                                ViewportUnits="RelativeToBoundingBox"
                                                Viewport="0,0,1,1"/>
                                </Grid.Background>
                                <!-- Page background image -->
                                <Rectangle x:Name="PreviewPageBg" Fill="#0a0a1a"/>
                                <!-- Top notification bar -->
                                <Border x:Name="PreviewBarTop" Height="18" VerticalAlignment="Top">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="PreviewBarBrush" Color="#ff000000"/>
                                    </Border.Background>
                                    <Grid>
                                        <!-- Left: time -->
                                        <TextBlock Text="12:00" FontSize="7"
                                                   VerticalAlignment="Center" Margin="4,0,0,0">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush x:Name="PreviewBarFontBrush" Color="#ffffffff"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <!-- Right: icons -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,4,0">
                                            <TextBlock Text="&#x25A0; &#x25A0; &#x25A0;"
                                                       FontSize="5" Margin="0,0,2,0">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush x:Name="PreviewIndicatorBrush" Color="#ffff7d00"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <!-- Fake app bubbles grid -->
                                <UniformGrid Rows="2" Columns="4"
                                             Margin="8,24,8,8" VerticalAlignment="Stretch">
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg1" Color="#44000000"/></Border.Background>
                                    </Border>
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg2" Color="#44000000"/></Border.Background>
                                    </Border>
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg3" Color="#44000000"/></Border.Background>
                                    </Border>
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg4" Color="#44000000"/></Border.Background>
                                    </Border>
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg5" Color="#44000000"/></Border.Background>
                                    </Border>
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg6" Color="#44000000"/></Border.Background>
                                    </Border>
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg7" Color="#44000000"/></Border.Background>
                                    </Border>
                                    <Border Margin="2" CornerRadius="4">
                                        <Border.Background><SolidColorBrush x:Name="BubbleBg8" Color="#44000000"/></Border.Background>
                                    </Border>
                                </UniformGrid>
                                <!-- Page indicator dots on left -->
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Margin="3,20,0,0">
                                    <Ellipse Width="4" Height="4" Margin="0,2" Fill="#ff7d00"/>
                                    <Ellipse Width="3" Height="3" Margin="0,2" Fill="#444444"/>
                                    <Ellipse Width="3" Height="3" Margin="0,2" Fill="#444444"/>
                                    <Ellipse Width="3" Height="3" Margin="0,2" Fill="#444444"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- BUBBLE FONT COLOR SWATCH -->
                        <TextBlock Text="Bubble Font" Foreground="#666666"
                                   FontSize="10" Margin="0,16,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14"
                                    BorderBrush="#333333" BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush x:Name="PreviewBubbleFontBrush" Color="#ffffffff"/>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="PreviewBubbleFontHex"
                                       Foreground="#555555" FontSize="10"
                                       FontFamily="Consolas" VerticalAlignment="Center"
                                       Margin="8,0,0,0" Text="ffffffff"/>
                        </StackPanel>

                        <!-- Disclaimer -->
                        <Border Margin="0,20,0,0" Padding="8,7" CornerRadius="5"
                                Background="#0f0f0f" BorderBrush="#2a2a2a" BorderThickness="1">
                            <TextBlock Foreground="#3a3a3a" FontSize="9"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       FontStyle="Italic"
                                       Text="Preview is a representation only. Final appearance may vary on device."/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- FOOTER NAV -->
        <Border Grid.Row="2" Background="#1c1c1c"
                BorderThickness="0,1,0,0" BorderBrush="#333333">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Back" Style="{StaticResource BtnGhost}"
                        x:Name="BtnBack" Click="BtnBack_Click" IsEnabled="False" Padding="18,10"/>
                <TextBlock x:Name="TxtStepIndicator" Grid.Column="1"
                           Foreground="#2e2e2e" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtFooterStatus" Grid.Column="1"
                           Foreground="#ff5555" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed" TextWrapping="Wrap"/>
                <Button Grid.Column="2" Content="Save &amp; Continue"
                        Style="{StaticResource BtnPrimary}"
                        x:Name="BtnNext" Click="BtnNext_Click"
                        Margin="0,0,10,0" Padding="18,10"/>
                <Button Grid.Column="3" Content="Save Now"
                        Style="{StaticResource BtnSecondary}"
                        x:Name="BtnSaveNow" Click="BtnSaveNow_Click"
                        IsEnabled="False" Padding="18,10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
