<UserControl x:Class="ColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ARGB text box -->
        <Border Grid.Column="0" Background="#1e1e1e" BorderBrush="#2e2e2e"
                BorderThickness="1" CornerRadius="6">
            <TextBox x:Name="TxtArgb"
                     Background="Transparent" Foreground="#f0f0f0"
                     BorderThickness="0" Padding="11,9"
                     FontSize="13" FontFamily="Consolas"
                     CaretBrush="#ff7d00" VerticalAlignment="Center"
                     TextChanged="TxtArgb_TextChanged"
                     MaxLength="8"/>
        </Border>

        <!-- Gem-style round color pick button -->
        <Button x:Name="BtnSwatch" Grid.Column="1"
                Width="38" Height="38"
                Margin="6,0,0,0"
                Cursor="Hand" Click="BtnSwatch_Click"
                ToolTip="Pick a color">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid Width="38" Height="38">
                        <!-- Drop shadow -->
                        <Ellipse Width="34" Height="34" Margin="0,3,0,0"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#000000" Opacity="0.45"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Gem body clipped to circle showing current color -->
                        <Ellipse Width="34" Height="34"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Fill="{Binding SwatchColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        <!-- Outer ring -->
                        <Ellipse x:Name="GemRing" Width="34" Height="34"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Stroke="#666666" StrokeThickness="1.5" Fill="Transparent"/>
                        <!-- Top gloss shine -->
                        <Ellipse Width="18" Height="10" Margin="0,5,0,0"
                                 HorizontalAlignment="Center" VerticalAlignment="Top"
                                 IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#99ffffff" Offset="0"/>
                                    <GradientStop Color="#00ffffff" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Bottom soft reflection -->
                        <Ellipse Width="12" Height="6" Margin="0,0,0,5"
                                 HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                 IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#33ffffff" Offset="0"/>
                                    <GradientStop Color="#00ffffff" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GemRing" Property="Stroke" Value="#ff7d00"/>
                            <Setter TargetName="GemRing" Property="StrokeThickness" Value="2.5"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="GemRing" Property="Stroke" Value="#ff9933"/>
                            <Setter TargetName="GemRing" Property="StrokeThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- COLOR WHEEL POPUP -->
        <Popup x:Name="ColorPopup" Grid.Column="1"
               PlacementTarget="{Binding ElementName=BtnSwatch}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False">

            <Border Background="#1a1a1a" BorderBrush="#ff7d00"
                    BorderThickness="1" CornerRadius="10"
                    Padding="16" MinWidth="300">
                <StackPanel>

                    <TextBlock Text="COLOR WHEEL" Foreground="#666666"
                               FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <!-- Wheel + SV square row -->
                    <Grid Width="260" Height="260" Margin="0,0,0,12">

                        <!-- Hue wheel canvas (drawn in code-behind) -->
                        <Canvas x:Name="WheelCanvas" Width="260" Height="260"
                                MouseDown="WheelCanvas_MouseDown"
                                MouseMove="WheelCanvas_MouseMove"
                                MouseUp="WheelCanvas_MouseUp"
                                Cursor="Cross"/>

                        <!-- SV square in the centre -->
                        <Canvas x:Name="SvCanvas" Width="140" Height="140"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MouseDown="SvCanvas_MouseDown"
                                MouseMove="SvCanvas_MouseMove"
                                MouseUp="SvCanvas_MouseUp"
                                Cursor="Cross">
                            <!-- SV gradient image drawn in code-behind -->
                            <Image x:Name="SvImage" Width="140" Height="140"/>
                            <!-- Crosshair marker -->
                            <Ellipse x:Name="SvMarker" Width="12" Height="12"
                                     Stroke="White" StrokeThickness="2"
                                     Fill="Transparent"
                                     Canvas.Left="64" Canvas.Top="64"/>
                        </Canvas>

                        <!-- Hue marker (ring on wheel) -->
                        <Ellipse x:Name="HueMarker" Width="14" Height="14"
                                 Stroke="White" StrokeThickness="2"
                                 Fill="Transparent"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 Margin="123,10,0,0"
                                 IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Alpha slider -->
                    <TextBlock Text="OPACITY" Foreground="#666666"
                               FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Grid Height="20" Margin="0,0,0,12">
                        <!-- Checkerboard background to show transparency -->
                        <Rectangle x:Name="AlphaBg" RadiusX="4" RadiusY="4"/>
                        <!-- Gradient overlay -->
                        <Rectangle x:Name="AlphaGradient" RadiusX="4" RadiusY="4"/>
                        <!-- Slider thumb -->
                        <Canvas x:Name="AlphaCanvas" Height="20"
                                MouseDown="AlphaCanvas_MouseDown"
                                MouseMove="AlphaCanvas_MouseMove"
                                MouseUp="AlphaCanvas_MouseUp"
                                Cursor="SizeWE">
                            <Rectangle x:Name="AlphaThumb"
                                       Width="8" Height="20"
                                       Fill="White" RadiusX="3" RadiusY="3"
                                       Stroke="#333333" StrokeThickness="1"
                                       Canvas.Left="0"/>
                        </Canvas>
                    </Grid>

                    <!-- Preview + ARGB value -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="28" CornerRadius="5"
                                BorderBrush="#333333" BorderThickness="1"
                                Margin="0,0,8,0">
                            <Border x:Name="PreviewBox" CornerRadius="4"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Foreground="#555555" FontSize="9" Margin="0,0,0,2">ARGB HEX</TextBlock>
                            <TextBlock x:Name="TxtCurrentArgb"
                                       Foreground="#aaaaaa" FontSize="12"
                                       FontFamily="Consolas" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
